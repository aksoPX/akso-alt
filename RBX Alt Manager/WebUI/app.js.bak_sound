const state={accounts:[],selectedUserId:-1};
const titles={dashboard:['Главная','Обзор аккаунтов, рисков и быстрых действий'],accounts:['Аккаунты','Поиск, выбор и управление аккаунтами'],launch:['Запуск','Place ID, Job ID и запуск Roblox'],games:['Игры','Серверы, избранное, universe, outfits и watcher'],profile:['Профиль','Локальные заметки, follow и браузер аккаунта'],security:['Безопасность','Риски, backup и буфер обмена'],tools:['Инструменты','Настройки, тема, Nexus и дополнительные окна']};
function send(action,data={}){window.chrome?.webview?.postMessage({action,data});}
function showPage(id){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.getElementById(id)?.classList.add('active');document.querySelectorAll('.nav-item').forEach(b=>b.classList.toggle('active',b.dataset.page===id));document.getElementById('pageTitle').textContent=titles[id][0];document.getElementById('pageSubtitle').textContent=titles[id][1];}
function toast(text){const el=document.getElementById('toast');el.textContent=text;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),2600)}
function render(){document.getElementById('statAccounts').textContent=state.accounts.length;document.getElementById('statSelected').textContent=state.accounts.filter(a=>a.selected).length;document.getElementById('statRisk').textContent=state.stats?.riskLevel||'низкий';document.getElementById('statWeb').textContent=state.stats?.webServer?'вкл':'выкл';['placeId','dashPlace'].forEach(id=>{const el=document.getElementById(id);if(el&&!el.matches(':focus'))el.value=state.placeId||''});['jobId','dashJob'].forEach(id=>{const el=document.getElementById(id);if(el&&!el.matches(':focus'))el.value=state.jobId||''});const fu=document.getElementById('followUser');if(fu&&!fu.matches(':focus'))fu.value=state.followUser||'';const al=document.getElementById('alias');if(al&&!al.matches(':focus'))al.value=state.alias||'';const de=document.getElementById('description');if(de&&!de.matches(':focus'))de.value=state.description||'';renderAccounts();}
function renderAccounts(){const box=document.getElementById('accountsList');const q=(document.getElementById('accountSearch').value||'').toLowerCase();const list=state.accounts.filter(a=>[a.username,a.alias,a.description,a.group,String(a.userId)].join(' ').toLowerCase().includes(q));box.innerHTML='';box.classList.toggle('empty',list.length===0);if(!list.length){box.textContent='Аккаунтов пока нет';return}for(const a of list){const card=document.createElement('div');card.className='account-card'+(a.selected?' selected':'');card.innerHTML=`<div class="account-name">${escapeHtml(a.username||'unknown')}</div><div class="account-meta">${escapeHtml(a.alias||'Без псевдонима')} · ${escapeHtml(a.group||'Default')}</div><div class="account-desc">${escapeHtml(a.description||'Нет описания')}</div><div class="account-meta">UserId: ${a.userId||''} · ${escapeHtml(a.lastUse||'не запускался')}</div>`;card.onclick=()=>send('selectAccount',{userId:a.userId});box.appendChild(card)}}
function escapeHtml(s){return String(s).replace(/[&<>'"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#039;','"':'&quot;'}[m]))}
document.querySelectorAll('.nav-item').forEach(b=>b.onclick=()=>showPage(b.dataset.page));document.addEventListener('click',e=>{const a=e.target.closest('[data-action]')?.dataset.action;if(!a)return;if(a==='launch')send('launch',{placeId:document.getElementById('placeId').value,jobId:document.getElementById('jobId').value});else if(a==='launchDash')send('launch',{placeId:document.getElementById('dashPlace').value,jobId:document.getElementById('dashJob').value});else if(a==='follow')send('follow',{username:document.getElementById('followUser').value});else if(a==='setAlias')send('setAlias',{alias:document.getElementById('alias').value});else if(a==='setDescription')send('setDescription',{description:document.getElementById('description').value});else send(a)});document.getElementById('accountSearch').addEventListener('input',renderAccounts);window.chrome?.webview?.addEventListener('message',e=>{const m=e.data;if(m.type==='state'){Object.assign(state,m);render()}if(m.type==='toast')toast(m.text)});send('ready');
